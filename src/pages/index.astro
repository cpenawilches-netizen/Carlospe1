---
import '../styles/global.css';

const categories = [
  { name: 'Mujer', detail: 'Sneakers, sandalias y botas para todos los dias' },
  { name: 'Hombre', detail: 'Casual, deportivo y cuero con horma comoda' },
  { name: 'Ninos', detail: 'Modelos resistentes para colegio y juego' },
  { name: 'Trabajo', detail: 'Botas, seguridad y suelas de alto agarre' },
];

const footwearTypes = [
  {
    id: 'bota-seguridad',
    name: 'Bota de seguridad',
    summary: 'Proteccion industrial con puntera, suela antideslizante y materiales resistentes.',
    products: [
      {
        name: 'Seguridad Pro S1',
        tag: 'Puntera',
        price: '$249.900',
        color: 'Negro',
        spec: 'Ideal para obra, bodega y planta',
      },
      {
        name: 'Terreno Max',
        tag: 'Antideslizante',
        price: '$289.900',
        color: 'Cafe',
        spec: 'Suela de alto agarre y cuello acolchado',
      },
      {
        name: 'Metal Free',
        tag: 'Ligera',
        price: '$269.900',
        color: 'Gris / negro',
        spec: 'Proteccion sin componentes metalicos',
      },
    ],
  },
  {
    id: 'bota-caucho',
    name: 'Bota de caucho',
    summary: 'Botas impermeables para lluvia, campo, aseo, alimentos y trabajo pesado.',
    products: [
      {
        name: 'Caucho Alta',
        tag: 'Impermeable',
        price: '$119.900',
        color: 'Negro',
        spec: 'Cana alta para humedad y lodo',
      },
      {
        name: 'Agro Flex',
        tag: 'Campo',
        price: '$139.900',
        color: 'Verde oliva',
        spec: 'Flexible para jornadas largas',
      },
      {
        name: 'Food Safe',
        tag: 'Aseo',
        price: '$129.900',
        color: 'Blanco',
        spec: 'Pensada para alimentos y limpieza',
      },
    ],
  },
];

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="InduProt: tienda colombiana de calzado industrial, botas de seguridad y botas de caucho."
    />
    <title>InduProt | Calzado industrial y de proteccion</title>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Inicio">
        <span class="brand-mark">IP</span>
        <span>InduProt</span>
      </a>
      <nav aria-label="Principal">
        <a href="#categorias">Categorias</a>
        <a href="#productos">Productos</a>
        <a href="#ventajas">Ventajas</a>
        <a href="#contacto">Contacto</a>
      </nav>
      <a class="nav-action" href="#productos">Comprar</a>
    </header>

    <main>
      <section class="hero">
        <img src="/images/hero-calzado.png" alt="Coleccion de zapatos en exhibicion comercial" />
        <div class="hero-overlay">
          <p class="eyebrow">Coleccion 2026</p>
          <h1>Calzado para caminar, trabajar y moverse mejor.</h1>
          <p>
            Una vitrina moderna para vender tenis, cuero, botas y sandalias con despacho en
            Colombia.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#productos">Ver destacados</a>
            <a class="button secondary" href="#contacto">Cotizar pedido</a>
          </div>
        </div>
      </section>

      <section class="promo-strip" aria-label="Beneficios">
        <span>Envios nacionales</span>
        <span>Cambios faciles</span>
        <span>Pagos seguros</span>
        <span>Asesoria por WhatsApp</span>
      </section>

      <section id="categorias" class="section">
        <div class="section-heading">
          <p class="eyebrow">Compra por categoria</p>
          <h2>Una entrada clara para cada cliente</h2>
        </div>
        <div class="category-grid">
          {categories.map((category) => (
            <article class="category-card">
              <h3>{category.name}</h3>
              <p>{category.detail}</p>
              <a href="#productos">Explorar</a>
            </article>
          ))}
        </div>
      </section>

      <section id="productos" class="section product-section">
        <div class="section-heading">
          <p class="eyebrow">Catalogo por tipo</p>
          <h2>Elige el calzado que necesita tu trabajo</h2>
        </div>

        <div
          class="type-tabs"
          id="catalogo-calzado"
          data-supabase-url={supabaseUrl}
          data-supabase-anon-key={supabaseAnonKey}
        >
          {footwearTypes.map((type, index) => (
            <input
              class="tab-input"
              type="radio"
              name="tipo-calzado"
              id={type.id}
              checked={index === 0}
            />
          ))}

          <div class="tab-list" role="tablist" aria-label="Tipos de calzado">
            {footwearTypes.map((type) => (
              <label class="tab-label" for={type.id}>{type.name}</label>
            ))}
          </div>

          <div class="type-panels">
            {footwearTypes.map((type) => (
              <article class="type-panel">
                <div class="type-intro">
                  <h3>{type.name}</h3>
                  <p>{type.summary}</p>
                  <a class="text-link" href="#contacto">Cotizar este tipo</a>
                </div>
                <div class="product-grid compact">
                  {type.products.map((product) => (
                    <article class="product-card">
                      <div class="shoe-visual" aria-hidden="true">
                        <span></span>
                      </div>
                      <div class="product-meta">
                        <span>{product.tag}</span>
                        <h3>{product.name}</h3>
                        <p>{product.color}</p>
                        <p>{product.spec}</p>
                        <strong>{product.price}</strong>
                      </div>
                    </article>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="ventajas" class="feature-band">
        <div>
          <p class="eyebrow">Pensado para ecommerce</p>
          <h2>Rapido, editable y listo para crecer</h2>
        </div>
        <div class="features">
          <article>
            <h3>Astro</h3>
            <p>Paginas rapidas, buen SEO y componentes faciles de mantener.</p>
          </article>
          <article>
            <h3>GitHub</h3>
            <p>Control de cambios para trabajar desde VS Code sin perder historial.</p>
          </article>
          <article>
            <h3>Cloudflare</h3>
            <p>Deploy automatico cada vez que se sube una mejora al repositorio.</p>
          </article>
        </div>
      </section>

      <section id="contacto" class="contact-section">
        <div>
          <p class="eyebrow">Siguiente paso</p>
          <h2>Conectemos catalogo, pagos y WhatsApp</h2>
          <p>
            Esta primera version deja la base visual lista. Luego podemos agregar productos reales,
            filtros, carrito, CMS o integracion con inventario.
          </p>
        </div>
        <a class="button primary" href="mailto:ventas@tumarca.com">ventas@tumarca.com</a>
      </section>
    </main>

    <script>
      const catalog = document.querySelector('#catalogo-calzado');
      const supabaseUrl = catalog?.dataset.supabaseUrl;
      const supabaseAnonKey = catalog?.dataset.supabaseAnonKey;

      const formatPrice = (value) => {
        if (value === null || value === undefined || value === '') {
          return 'Cotizar';
        }

        return new Intl.NumberFormat('es-CO', {
          style: 'currency',
          currency: 'COP',
          maximumFractionDigits: 0,
        }).format(Number(value));
      };

      const renderCatalog = (types) => {
        if (!catalog || !types.length) return;

        catalog.innerHTML = `
          <div class="tab-list" role="tablist" aria-label="Tipos de calzado">
            ${types
              .map(
                (type, index) => `
                  <button
                    class="tab-label ${index === 0 ? 'is-active' : ''}"
                    type="button"
                    data-tab-target="${type.slug}"
                  >
                    ${type.nombre}
                  </button>
                `,
              )
              .join('')}
          </div>

          <div class="type-panels">
            ${types
              .map(
                (type, index) => `
                  <article class="type-panel ${index === 0 ? 'is-active' : ''}" data-tab-panel="${type.slug}">
                    <div class="type-intro">
                      <h3>${type.nombre}</h3>
                      <p>${type.descripcion ?? ''}</p>
                      <a class="text-link" href="#contacto">Cotizar este tipo</a>
                    </div>
                    <div class="product-grid compact">
                      ${type.productos
                        .map(
                          (product) => `
                            <article class="product-card">
                              <div class="shoe-visual" aria-hidden="true">
                                ${
                                  product.imagen_url
                                    ? `<img src="${product.imagen_url}" alt="${product.nombre}" loading="lazy" />`
                                    : '<span></span>'
                                }
                              </div>
                              <div class="product-meta">
                                <span>${product.etiqueta ?? 'Producto'}</span>
                                <h3>${product.nombre}</h3>
                                <p>${product.color ?? ''}</p>
                                <p>${product.descripcion ?? ''}</p>
                                <strong>${formatPrice(product.precio)}</strong>
                              </div>
                            </article>
                          `,
                        )
                        .join('')}
                    </div>
                  </article>
                `,
              )
              .join('')}
          </div>
        `;

        catalog.querySelectorAll('[data-tab-target]').forEach((tab) => {
          tab.addEventListener('click', () => {
            const target = tab.getAttribute('data-tab-target');

            catalog.querySelectorAll('[data-tab-target]').forEach((item) => {
              item.classList.toggle('is-active', item === tab);
            });

            catalog.querySelectorAll('[data-tab-panel]').forEach((panel) => {
              panel.classList.toggle('is-active', panel.getAttribute('data-tab-panel') === target);
            });
          });
        });
      };

      const loadCatalogFromSupabase = async () => {
        if (
          !catalog ||
          !supabaseUrl ||
          !supabaseAnonKey ||
          supabaseUrl === 'undefined' ||
          supabaseAnonKey === 'undefined'
        ) {
          return;
        }

        const url = new URL('/rest/v1/tipos_calzado', supabaseUrl);
        url.searchParams.set('select', 'id,nombre,slug,descripcion,orden,productos(*)');
        url.searchParams.set('activo', 'eq.true');
        url.searchParams.set('productos.disponible', 'eq.true');
        url.searchParams.set('order', 'orden.asc');

        const response = await fetch(url, {
          headers: {
            apikey: supabaseAnonKey,
            Authorization: `Bearer ${supabaseAnonKey}`,
          },
        });

        if (!response.ok) {
          throw new Error('No se pudo cargar el catalogo desde Supabase');
        }

        const types = await response.json();
        const orderedTypes = types.map((type) => ({
          ...type,
          productos: [...(type.productos ?? [])].sort((a, b) => (a.orden ?? 0) - (b.orden ?? 0)),
        }));

        renderCatalog(orderedTypes);
      };

      loadCatalogFromSupabase().catch((error) => {
        console.warn(error);
      });
    </script>
  </body>
</html>
